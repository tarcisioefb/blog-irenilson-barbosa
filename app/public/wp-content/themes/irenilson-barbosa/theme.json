				{
					"slug": "70",
					"name": "2xl",
					"size": "clamp(2rem, 4vw, 3rem)"
				},
				{
					"slug": "80",
					"name": "3xl",
					"size": "clamp(3rem, 6vw, 4rem)"
				}
			]
		},
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		}
