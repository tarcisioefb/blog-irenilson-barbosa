	"styles": {
		"color": {
			"background": "var:preset|color|bege-100",
			"text": "var:preset|color|marrom-600"
		},
		"elements": {
			"h1": {
				"color": {
					"text": "var:preset|color|marrom-800"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"color": {
					"text": "var:preset|color|marrom-800"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata",
					"lineHeight": "1.25"
				}
			},
			"h3": {
				"color": {
					"text": "var:preset|color|marrom-800"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"color": {
					"text": "var:preset|color|marrom-700"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata"
				}
			},
			"h5": {
				"color": {
					"text": "var:preset|color|marrom-700"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata"
				}
			},
			"h6": {
				"color": {
					"text": "var:preset|color|marrom-700"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|literata"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|verde-600"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|verde-800"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var:preset|color|marrom-400"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|marrom-800",
					"text": "var:preset|color|branco"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|marrom-900"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|inter"
				},
				"border": {
					"radius": "4px"
				}
			}
		},
		"blocks": {
			"core/quote": {
				"color": {
					"background": "var:preset|color|bege-50"
				},
				"elements": {
					"citation": {
						"color": {
							"text": "var:preset|color|marrom-400"
						},
						"typography": {
							"fontSize": "var:preset|font-size|small"
						}
					}
				},
				"border": {
					"left": {
						"color": "var:preset|color|verde-700",
						"width": "4px",
						"style": "solid"
					}
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/pullquote": {
				"color": {
					"text": "var:preset|color|marrom-800"
				},
				"border": {
					"top": {
						"color": "var:preset|color|bege-300",
						"width": "1px",
						"style": "solid"
					},
					"bottom": {
						"color": "var:preset|color|bege-300",
						"width": "1px",
						"style": "solid"
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var:preset|color|bege-300"
				}
			},
			"core/post-terms": {
				"color": {
					"text": "var:preset|color|verde-700"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|inter",
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/tag-cloud": {
				"typography": {
					"fontFamily": "var:preset|font-family|inter"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|literata"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|literata"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var:preset|font-family|inter",
					"fontSize": "var:preset|font-size|medium"
				}
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|inter",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.75"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|50"
		}
	}
}
